# Application Settings
DEBUG=True
APP_ENV=development

# ===== Platform (卡密/配额/多用户) =====
# 本地开发默认 SQLite；生产建议 postgresql+asyncpg://user:pass@host:5432/deerflow
# PLATFORM_DATABASE_URL=sqlite+aiosqlite:///./deerflow_platform.db
# 必填：JWT 签名密钥（不设则每次重启所有登录失效）
# PLATFORM_JWT_SECRET=change-me-to-a-long-random-string
# 必填：管理后台令牌（发卡/用户管理用）
# ADMIN_TOKEN=change-me-too
# 前端域名（CORS 白名单，逗号分隔）
# PLATFORM_ALLOWED_ORIGINS=http://localhost:3000
# 单任务 token 熔断上限（默认 500000）
# PLATFORM_TASK_TOKEN_CAP=500000
# 卖家级每日 token 总预算，0=不限（强烈建议按上游账单承受力设置）
# PLATFORM_DAILY_TOKEN_BUDGET=0
# 全局同时运行任务上限（对齐上游 RPM/TPM 配额）
# PLATFORM_MAX_CONCURRENT_RUNS=3
# 服务端步数/搜索条数硬上限（防参数拉满薅 token）
# PLATFORM_MAX_STEP_NUM=3
# PLATFORM_MAX_SEARCH_RESULTS=3
# 告警 webhook（每日预算熔断等）：飞书/钉钉/Server酱 均可
# PLATFORM_ALERT_WEBHOOK=

# 上游模型 API keys（models 表的 api_key_env 引用这些变量名）
# VOLCENGINE_ARK_API_KEY=   # 火山方舟
# DASHSCOPE_API_KEY=        # 阿里云百炼

# docker build args
NEXT_PUBLIC_API_URL="http://0.0.0.0:8000/api"

AGENT_RECURSION_LIMIT=30

# Search Engine, Supported values: tavily (recommended), duckduckgo, brave_search, arxiv, spark
SEARCH_API=tavily
TAVILY_API_KEY=tvly-xxx
# BRAVE_SEARCH_API_KEY=xxx # Required only if SEARCH_API is brave_search
# JINA_API_KEY=jina_xxx # Optional, default is None
# SPARK_API_KEY=xxx
# SPARK_APP_ID=xxx
# SPARK_API_SECRET=xxx

# Optional, volcengine TTS for generating podcast
VOLCENGINE_TTS_APPID=xxx
VOLCENGINE_TTS_ACCESS_TOKEN=xxx
# VOLCENGINE_TTS_CLUSTER=volcano_tts # Optional, default is volcano_tts
# VOLCENGINE_TTS_VOICE_TYPE=BV700_V2_streaming # Optional, default is BV700_V2_streaming

# Option, for langsmith tracing and monitoring
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
# LANGSMITH_API_KEY="xxx"
# LANGSMITH_PROJECT="xxx"

# [!NOTE]
# For model settings and other configurations, please refer to `docs/configuration_guide.md`
